# =============================
# 模型服务（model_service）示例配置
#
# 用法：复制为 .env 放到仓库根目录，然后按需修改。
# 说明：这些变量会被 model_service/settings.py 读取。
# =============================

# 服务名：影响 FastAPI 的 title（可不改）
SERVICE_NAME=knowledge_rag_model_service

# -----------------------------
# Embedding（向量化）模型设置
# -----------------------------

# Embedding 模型（SentenceTransformer 可加载的模型名/路径）
EMBED_MODEL=BAAI/bge-base-zh-v1.5

# Embedding 维度：必须与“入库时使用的模型维度”和 Qdrant collection 的 size 一致
EMBED_DIM=768

# 是否对向量做归一化（cosine 相似度场景一般建议 true）
NORMALIZE_EMBEDDINGS=true

# -----------------------------
# Rerank（精排）模型设置（可选）
# -----------------------------

# 不配置则 /rerank 返回 501（表示暂未启用精排）
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -----------------------------
# Retrieval（检索）相关：Qdrant
# -----------------------------

# Qdrant 服务地址（对应 docker-compose 暴露的 6333 端口）
QDRANT_URL=http://localhost:6333

# Qdrant collection 名称（入库脚本 offline_indexing.py 默认也是 knowledge_chunks）
QDRANT_COLLECTION=knowledge_chunks

# -----------------------------
# 检索后处理：邻居扩展 / 连续合并
# -----------------------------

# 邻居窗口 w：命中 chunk 后，会额外拉取同文档相邻 page_num 的 chunk。
# 例如 w=1 会扩展 page_num±1，然后把连续 page_num 的内容合并返回。
# 取值建议：0（不扩展）/ 1（默认）/ 2（更长上下文，但更可能引入噪声）。
NEIGHBOR_WINDOW=1
